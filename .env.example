# Frontend (Vite) — used by the React app
VITE_API_URL=https://your-api-id.execute-api.us-east-1.amazonaws.com
VITE_WS_URL=wss://your-ws-id.execute-api.us-east-1.amazonaws.com/prod
VITE_USER_POOL_ID=us-east-1_XXXXXXXXX
VITE_USER_POOL_CLIENT_ID=xxxxxxxxxxxxxxxxxxxxxxxxxx
VITE_COGNITO_DOMAIN=coloring-book-studio.auth.us-east-1.amazoncognito.com

# Lambda environment variables — set via CDK stack or AWS console, NOT in this file
# TURSO_DATABASE_URL=libsql://your-db.turso.io
# TURSO_AUTH_TOKEN=your-turso-token
# OPENROUTER_API_KEY=sk-or-...
# GEMINI_API_KEY=AIza...
# S3_BUCKET_NAME=coloring-book-studio-images-123456789
# ALLOWED_ORIGINS=http://localhost:5173,https://your-domain.com

# Legacy local server (only needed if using server/index.js)
# GEMINI_API_KEY=your_gemini_api_key
# GEMINI_MODEL=gemini-2.5-flash-preview-09-2025
# GEMINI_CHAT_MODEL=gemini-2.0-flash
# CLOUDINARY_CLOUD_NAME=your_cloud_name
# CLOUDINARY_API_KEY=your_api_key
# CLOUDINARY_API_SECRET=your_api_secret
